# Voicenotes MCP — environment variables. Copy to .env and edit as needed.
# ALL are optional; sensible defaults are baked in.

# --- Transport selection ---
# Set MCP_HTTP_PORT to run the Streamable HTTP server (Claude.ai web connector).
# Leave unset to run over stdio (Claude Code / Claude Desktop).
# MCP_HTTP_PORT=3001

# Public URL the HTTP server is reachable at (the OAuth "resource" identifier).
# Defaults to http://localhost:<MCP_HTTP_PORT>. Set this when deploying remotely.
# MCP_PUBLIC_URL=https://your-domain.example.com

# Host the HTTP server binds to. Defaults to 127.0.0.1 (loopback, safest).
# Only change when behind a trusted TLS-terminating reverse proxy.
# MCP_BIND_HOST=127.0.0.1

# Comma-separated allowlist of Origins permitted to call the HTTP transport.
# Default: https://claude.ai,https://www.claude.ai,http://localhost,http://127.0.0.1
# MCP_ALLOWED_ORIGINS=https://claude.ai

# --- OAuth (stdio flow) ---
# Local loopback port for the OAuth callback. Must be free. Default 9876.
# VN_CALLBACK_PORT=9876
