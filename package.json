{
  "name": "voicenotes-mcp",
  "version": "1.0.0",
  "description": "Custom MCP server for Voicenotes with OAuth 2.1 + PKCE + Dynamic Client Registration. stdio + Streamable HTTP transports.",
  "type": "module",
  "bin": {
    "voicenotes-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "MCP_HTTP_PORT=3001 node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "keytar": "^7.9.0",
    "open": "^10.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
